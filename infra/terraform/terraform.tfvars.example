# =============================================================================
# Example values — copy to terraform.tfvars and fill in your own
# =============================================================================
# DO NOT commit terraform.tfvars. It's already in .gitignore.
# Copy this file:  cp terraform.tfvars.example terraform.tfvars
# =============================================================================

# These values are the future Amber config inputs that should map directly into
# Terraform variables. For manual testing, copy this file to terraform.tfvars and
# edit them here.
#
# Use a short, lowercase, hyphenated project name to avoid AWS name limits.
# Allowed environments are dev, staging, and prod.
project_name = "amber"
environment  = "dev"
region       = "us-east-1"

# Customer app entrypoints. The CLI writes these from amber.yaml.
asgi_app      = "example_customer_app.main:app"
worker_target = "example_customer_app.main:agent_runtime"
path_prefix   = "/api"

# The frontend S3 bucket is generated as:
#   <project_name>-<environment>-<aws_account_id>-frontend
# Example:
#   amber-dev-123456789012-frontend
#
# Dev/test default: let terraform destroy delete frontend assets and all object
# versions. Set false for production-like stacks where asset history should not
# be silently deleted during destroy.
frontend_bucket_force_destroy = true

# Dev/test default: skip the Secrets Manager recovery window so terraform destroy
# purges the db secrets immediately and their names can be reused on the next
# apply. Set false for production-like stacks to keep a 30-day recovery window.
secrets_force_destroy = true

# Database. Leave db_password unset to let Terraform generate one and store it
# in Secrets Manager.
db_name     = "app"
db_username = "dbadmin"
# db_password = "generate-me-or-set-manually"

# RDS sizing. Bump these for production.
db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20

# Worker sizing. Amber CLI can expose these as config values later; changing
# concurrency requires an ECS worker redeploy/restart.
worker_concurrency = 8

# Dev/staging defaults cap worker scale-out at 2 tasks. Prod defaults to 4 when
# worker_max_tasks is left unset.
# worker_min_tasks     = 1
# worker_max_tasks     = 2
# worker_backlog_target = 8
